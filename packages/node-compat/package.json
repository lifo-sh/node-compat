{
  "name": "@lifo-sh/node-compat",
  "version": "0.1.7",
  "description": "Node.js API compatibility layer for browsers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js",
      "require": "./dist/fs.cjs"
    },
    "./path": {
      "types": "./dist/path.d.ts",
      "import": "./dist/path.js",
      "require": "./dist/path.cjs"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js",
      "require": "./dist/events.cjs"
    },
    "./buffer": {
      "types": "./dist/buffer.d.ts",
      "import": "./dist/buffer.js",
      "require": "./dist/buffer.cjs"
    },
    "./process": {
      "types": "./dist/process.d.ts",
      "import": "./dist/process.js",
      "require": "./dist/process.cjs"
    },
    "./util": {
      "types": "./dist/util.d.ts",
      "import": "./dist/util.js",
      "require": "./dist/util.cjs"
    },
    "./timers": {
      "types": "./dist/timers.d.ts",
      "import": "./dist/timers.js",
      "require": "./dist/timers.cjs"
    },
    "./os": {
      "types": "./dist/os.d.ts",
      "import": "./dist/os.js",
      "require": "./dist/os.cjs"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "import": "./dist/stream.js",
      "require": "./dist/stream.cjs"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.js",
      "require": "./dist/url.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js",
      "require": "./dist/crypto.cjs"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js",
      "require": "./dist/http.cjs"
    },
    "./console": {
      "types": "./dist/console.d.ts",
      "import": "./dist/console.js",
      "require": "./dist/console.cjs"
    },
    "./child_process": {
      "types": "./dist/child_process.d.ts",
      "import": "./dist/child_process.js",
      "require": "./dist/child_process.cjs"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js",
      "require": "./dist/module.cjs"
    },
    "./rimraf": {
      "types": "./dist/rimraf.d.ts",
      "import": "./dist/rimraf.js",
      "require": "./dist/rimraf.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js",
      "require": "./dist/esbuild.cjs"
    },
    "./dns": {
      "types": "./dist/dns.d.ts",
      "import": "./dist/dns.js",
      "require": "./dist/dns.cjs"
    },
    "./readline": {
      "types": "./dist/readline.d.ts",
      "import": "./dist/readline.js",
      "require": "./dist/readline.cjs"
    },
    "./string_decoder": {
      "types": "./dist/string_decoder.d.ts",
      "import": "./dist/string_decoder.js",
      "require": "./dist/string_decoder.cjs"
    },
    "./tty": {
      "types": "./dist/tty.d.ts",
      "import": "./dist/tty.js",
      "require": "./dist/tty.cjs"
    },
    "./zlib": {
      "types": "./dist/zlib.d.ts",
      "import": "./dist/zlib.js",
      "require": "./dist/zlib.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@lifo-sh/kernel": ">=0.1.0",
    "picomatch": "^4.0.3"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2",
    "tsup": "^8.0.0"
  }
}
